{
  "name": "oneshot-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:client": "pnpm --filter @oneshot/client dev",
    "dev:server": "pnpm --filter @oneshot/server dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "test:e2e": "pnpm --filter @oneshot/e2e test:e2e",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@playwright/test": "^1.49.1",
    "@types/node": "^22.10.6",
    "eslint": "^9.18.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vitest": "^3.2.4"
  },
  "pnpm": {
    "comment": "Security overrides — force patched transitive dev tooling (vite/esbuild advisories). All are dev/test-only; the deployed server bundle is unaffected.",
    "overrides": {
      "vite@<6.4.3": ">=6.4.3",
      "esbuild@<0.25.10": "~0.25.10"
    }
  }
}
